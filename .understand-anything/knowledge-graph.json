  "tour": [
    {
      "order": 1,
      "title": "Project Welcome & Overview",
      "description": "Start here to understand the repository's mission: developing collision avoidance and dynamic obstacle tracking for drones. This landing page provides the directory structure, local setup instructions, and data validation details.",
      "nodeIds": [
        "document:README.md"
      ]
    },
    {
      "order": 2,
      "title": "Development Reference Manual",
      "description": "Examine the reference guide that outlines CLI commands, the three-stage computer vision processing pipeline design (Detection -> Tracking -> Avoidance), and model training configurations.",
      "nodeIds": [
        "document:CLAUDE.md"
      ]
    },
    {
      "order": 3,
      "title": "Main Application Pipeline",
      "description": "Explore the primary execution entry point. This file handles input from camera or video feeds and orchestrates frame-by-frame processing across detection, tracking, planning, and visualization modules.",
      "nodeIds": [
        "file:main.py"
      ],
      "languageLesson": "In Python, the `if __name__ == '__main__':` boilerplate ensures that the main pipeline is only executed when run as a script directly, and not when imported as a module elsewhere."
    },
    {
      "order": 4,
      "title": "Real-Time Canvas Visualizer",
      "description": "See how tracking results and planning commands are rendered onto video frames in real time. This module uses OpenCV to overlay bounding boxes, identifiers, and flight action cues.",
      "nodeIds": [
        "file:src/utils/visualizer.py"
      ]
    },
    {
      "order": 5,
      "title": "Obstacle Detection Foundation",
      "description": "Dive into the base representations of detected objects. This file sets up standard dataclass structures and base classes that form the first stage of the computer vision pipeline.",
      "nodeIds": [
        "file:src/detection/detector.py"
      ],
      "languageLesson": "Using Python's `@dataclass` decorator allows for clean, declarative modeling of bounding box measurements and confidence levels with automatic constructor and string representation generation."
    },
    {
      "order": 6,
      "title": "Object Tracking & Association",
      "description": "Explore the tracking stage which links independent frame detections across time. It defines abstract structures and tracker interfaces responsible for maintaining object IDs and paths.",
      "nodeIds": [
        "file:src/tracking/tracker.py"
      ]
    },
    {
      "order": 7,
      "title": "Collision Avoidance Planning",
      "description": "Analyze the final decision-making layer of the flight control chain. This script defines base planning interfaces that calculate collision risks and determine avoidance trajectories.",
      "nodeIds": [
        "file:src/avoidance/planner.py"
      ]
    },
    {
      "order": 8,
      "title": "Dataset Integrity Validation",
      "description": "Learn how incoming training data and annotations are checked for health. This toolset validates video structures and YOLO formatting to prevent faulty data from corrupting neural network training.",
      "nodeIds": [
        "file:scripts/validate_data.py",
        "file:src/utils/data_validation.py"
      ]
    },
    {
      "order": 9,
      "title": "Model Training & Evaluation",
      "description": "Review the workflows for deep learning workflows. This set of nodes details dataset configuration, hyperparameter setup, train runs, and offline evaluation protocols for the obstacle detection model.",
      "nodeIds": [
        "file:scripts/train.py",
        "file:scripts/evaluate.py",
        "document:docs/training_pipeline.md"
      ]
    },
    {
      "order": 10,
      "title": "Unit Testing & Verification",
      "description": "Inspect the testing suite which validates the system's accuracy. Using pytest, these suites assert the behavioral correctness of tracking logic, detection fields, and data validation routines.",
      "nodeIds": [
        "file:tests/test_detection.py",
        "file:tests/test_tracking.py",
        "file:tests/test_data_validation.py"
      ],
      "languageLesson": "Pytest uses simple `assert` statements instead of verbose boilerplate like `self.assertEqual`, and automatically manages resources via modular, reusable `@pytest.fixture` functions."
    }
  ]
